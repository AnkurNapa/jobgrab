{
  "manifest_version": 3,
  "name": "JobGrab - LinkedIn Job Tracker",
  "version": "0.1.1",
  "description": "One-click save LinkedIn jobs into a Kanban tracker. A Teal-style job search companion.",
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "host_permissions": ["https://*.linkedin.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "JobGrab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content/scraper.js", "content/inject.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png", "icons/icon128.png"],
      "matches": ["https://*.linkedin.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
